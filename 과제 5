#include <stdio.h>
#include <string.h>

int main() {
    char str[100]; // 문장 및 문자열을 저장할 배열 선언

    /*
     * [입력 방법 설명: gets / fgets 미사용]
     * - 서식 지정자 "%99[^\n]"는 줄바꿈 문자의 개행('\n')이 나오기 전까지
     *   공백(space)을 포함한 모든 문자(최대 99자)를 한 번에 읽어옵니다.
     * - scanf의 반환값을 통해 입력 성공 여부를 검증하여 런타임 에러를 방지합니다.
     */
    if (scanf("%99[^\n]", str) != 1) {
        printf("올바르지 않은 입력입니다.\n");
        return 1;
    }

    // 1. 포인터를 직접 이동시키며 문자열의 실제 길이(len) 구하기
    int len = 0;
    char* ptr = str; // ptr 포인터가 문자열 배열의 시작 주소(첫 글자)를 가리킴

    while (*ptr != '\0') { // 널 문자를 만날 때까지 반복
        len++;             // 글자 수 증가
        ptr++;             // 포인터를 다음 문자의 주소로 1바이트 이동
    }

    // 2. 문장 거꾸로 출력하기 (포인터 활용)
    // ptr을 문자열의 마지막 실제 문자 위치(str + len - 1)로 이동시킵니다.
    ptr = str + len - 1;

    // 포인터 주소가 문자열의 시작 주소(str)보다 크거나 같을 때까지 1씩 뒤로 이동하며 출력
    while (ptr >= str) {
        putchar(*ptr); // 포인터가 가리키는 현재 위치의 문자 1개 출력
        ptr--;         // 포인터를 이전 문자의 주소로 1바이트 이동 (역순)
    }
    printf("\n");      // 거꾸로 출력 완료 후 줄바꿈

    // 3. 최다 등장 문자 찾기 (포인터 활용)
    int count[256] = { 0 }; // ASCII 코드 값(0~255)에 대응하는 문자의 빈도수를 저장하는 배열 (0으로 초기화)

    ptr = str; // 포인터를 다시 문자열의 시작 주소로 이동
    while (*ptr != '\0') {
        // 문제 조건: 공백(' ')은 등장 문자 카운트에서 제외
        if (*ptr != ' ') {
            // 해당 문자의 ASCII 값 위치의 빈도 카운트를 1 증가
            count[(unsigned char)*ptr]++;
        }
        ptr++; // 다음 문자로 이동
    }

    // 4. 빈도수 배열을 순회하여 가장 많이 등장한 문자 탐색
    char max_char = '\0'; // 가장 빈도수가 높은 문자를 저장할 변수
    int max_count = 0;    // 가장 높은 빈도수를 저장할 변수

    ptr = str; // 포인터를 다시 문자열 시작 지점으로 초기화하여 재탐색
    while (*ptr != '\0') {
        // 공백이 아니고, 해당 문자의 빈도수가 현재 max_count보다 큰 경우
        if (*ptr != ' ' && count[(unsigned char)*ptr] > max_count) {
            max_count = count[(unsigned char)*ptr]; // 최다 빈도수 갱신
            max_char = *ptr;                         // 최다 등장 문자 갱신
        }
        ptr++; // 다음 문자로 이동
    }

    // 5. 결과 출력
    if (max_count > 0) {
        printf("최다등장문자 : %c\n", max_char);
    } else {
        printf("등장한 문자가 없습니다.\n");
    }

    return 0;
}
