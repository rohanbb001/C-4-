#include <stdio.h>
#include <stdlib.h>  // malloc, free 동적 할당 함수 사용을 위한 헤더
#include <math.h>    // sqrt, pow 수학 함수 사용을 위한 헤더

// 2차원 평면 위의 점(좌표)을 나타내는 구조체 정의
typedef struct {
    int x; // x 좌표
    int y; // y 좌표
} Point;

// 두 점 p1과 p2 사이의 피타고라스 정리 기반 유클리드 거리를 구하는 함수
double calculate_distance(Point p1, Point p2) {
    // pow(a, 2)는 a의 제곱, sqrt()는 제곱근(루트)을 계산합니다.
    return sqrt(pow(p1.x - p2.x, 2) + pow(p1.y - p2.y, 2));
}

int main() {
    int n;

    // 1. 입력받을 좌표의 개수 N 입력
    // scanf의 반환값이 1이 아니거나 N이 0 이하인 경우 (문자 입력 등 예외 처리)
    if (scanf("%d", &n) != 1 || n <= 0) {
        printf("잘못된 입력입니다. 올바른 자연수를 입력해주세요.\n");
        return 1; // 비정상 종료 처리
    }

    // 2. 입력받은 개수 N에 맞추어 좌표 구조체 배열을 동적 할당 (메모리 최적화)
    Point* points = (Point*)malloc(sizeof(Point) * n);
    if (points == NULL) { // 메모리가 정상적으로 할당되지 않은 경우 예외 처리
        printf("메모리 할당 실패\n");
        return 1;
    }

    // 3. N개의 (x, y) 좌표들을 입력받기
    for (int i = 0; i < n; i++) {
        // 정수가 아닌 문자가 들어오거나 값이 모자란 경우 예외 처리
        if (scanf("%d %d", &points[i].x, &points[i].y) != 2) {
            printf("좌표 입력이 올바르지 않습니다.\n");
            free(points); // 이미 할당된 메모리를 해제하여 메모리 누수 방지
            return 1;
        }
    }

    /*
     * [문제 해결 의도 및 거리 계산 로직 상세 설명]
     * - 각 좌표(i번째 점)를 기준점으로 삼습니다.
     * - 자기 자신을 제외한 다른 모든 좌표(j번째 점)들과의 거리를 각각 구해 총합(current_sum)을 계산합니다.
     * - 다른 점들과의 거리의 총합이 가장 큰 점을 "가장 멀리 떨어진 좌표"로 판별합니다.
     * - 동일한 최댓값이 나올 경우, 가장 먼저 입력된 좌표의 인덱스를 유지하도록 처리되었습니다.
     */

    int max_index = 0;      // 가장 거리가 먼 좌표의 인덱스를 저장할 변수
    double max_sum = -1.0;  // 지금까지 구한 최대 거리 총합을 저장 (최초 비교를 위해 음수로 초기화)

    // 4. 모든 좌표를 순회하며 각 좌표별 다른 점들과의 거리 합계 계산
    for (int i = 0; i < n; i++) {
        double current_sum = 0.0; // i번째 좌표의 거리 총합 변수 초기화

        for (int j = 0; j < n; j++) {
            // 자기 자신과의 거리는 0이므로 i != j 조건일 때만 거리를 구함
            if (i != j) {
                current_sum += calculate_distance(points[i], points[j]);
            }
        }

        // 현재 좌표의 거리 총합이 기존 최댓값보다 크면 최댓값 및 해당 인덱스 갱신
        if (current_sum > max_sum) {
            max_sum = current_sum;
            max_index = i;
        }
    }

    // 5. 최종 결과 출력 (소수점 첫째 자리까지 출력)
    printf("가장 거리가 먼 좌표는 (%d, %d)이며, 다른 좌표의 거리 총합은 약 %.1f입니다.\n",
           points[max_index].x, points[max_index].y, max_sum);

    // 6. 사용을 마친 동적 메모리 해제
    free(points);
    return 0;
}
