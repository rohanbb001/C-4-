#include <stdio.h>
#include <string.h> // strcmp 함수 사용을 위한 헤더

// 학생 정보를 저장할 구조체 정의
typedef struct {
    int grade;       // 학년
    double score;    // 성적
    char name[50];   // 이름 (최대 49자 + 널 문자)
} Student;

int main() {
    Student students[5]; // 5명의 학생 정보를 저장할 구조체 배열 선언

    // 1. 5명의 학생 정보 입력 받기
    for (int i = 0; i < 5; i++) {
        // [예외 처리] 학년(정수), 성적(실수), 이름(문자열)이 올바르게 입력되었는지 확인
        if (scanf("%d %lf %s", &students[i].grade, &students[i].score, students[i].name) != 3) {
            printf("잘못된 입력 형식입니다.\n");
            return 1; // 비정상 종료
        }
    }

    // 2. 버블 정렬 알고리즘을 사용한 다중 조건 오름차순 정렬
    // 5개 요소를 정렬하기 위해 외부는 4번(5-1) 반복합니다.
    for (int i = 0; i < 5 - 1; i++) {
        // 내부 루프는 정렬이 확정된 자리를 제외하고 비교합니다.
        for (int j = 0; j < 5 - 1 - i; j++) {
            int swap = 0; // 두 학생의 자리를 바꿀지 여부를 결정하는 플래그 변수 (0: 유지, 1: 교환)

            // 조건 1: 학년이 더 크면 자리를 바꿉니다 (학년 오름차순).
            if (students[j].grade > students[j + 1].grade) {
                swap = 1;
            } 
            // 조건 2: 학년이 같으면 성적을 비교합니다.
            else if (students[j].grade == students[j + 1].grade) {
                // 성적이 더 크면 자리를 바꿉니다 (성적 오름차순).
                if (students[j].score > students[j + 1].score) {
                    swap = 1;
                } 
                // 조건 3: 학년과 성적이 모두 같으면 이름을 비교합니다.
                else if (students[j].score == students[j + 1].score) {
                    // strcmp는 앞 문자열이 사전순으로 뒤에 있으면 양수(>0)를 반환합니다.
                    // 이름이 사전순(알파벳순)으로 더 뒤에 있으면 자리를 바꿉니다.
                    if (strcmp(students[j].name, students[j + 1].name) > 0) {
                        swap = 1;
                    }
                }
            }

            // swap 플래그가 1로 켜졌다면 임시 변수(temp)를 이용해 구조체 통째로 자리를 바꿉니다.
            if (swap) {
                Student temp = students[j];
                students[j] = students[j + 1];
                students[j + 1] = temp;
            }
        }
    }

    // 3. 정렬이 완료된 결과 출력
    for (int i = 0; i < 5; i++) {
        // 성적은 소수점 첫째 자리까지("%.1f") 출력합니다.
        printf("%d %.1f %s\n", students[i].grade, students[i].score, students[i].name);
    }

    return 0;
}
