#include <stdio.h>

// 2차원 배열 포인터를 매개변수로 받아 3x4 격자 배열을 출력하는 함수
// int (*arr)[4]는 열(Column) 크기가 4인 2차원 배열을 가리키는 포인터입니다.
void print_board(int (*arr)[4]) {
    for (int i = 0; i < 3; i++) {
        for (int j = 0; j < 4; j++) {
            // 포인터 역참조 표현식 기법 반영: arr[i][j]와 동일한 의미입니다.
            printf("%d", *(*(arr + i) + j));
        }
        printf("\n"); // 한 행 출력이 끝나면 줄바꿈
    }
}

int main() {
    int board[3][4]; // 3행 4열 크기의 도형 역할을 할 2차원 배열 선언
    int n1, n2, n3;

    // 1. 첫 번째 임의의 숫자 입력 받기
    if (scanf("%d", &n1) != 1) {
        printf("잘못된 입력입니다.\n");
        return 1;
    }
    
    // 포인터 조작을 통해 모든 배열 공간을 첫 번째 입력된 숫자(n1)로 채움
    for (int i = 0; i < 3; i++) {
        for (int j = 0; j < 4; j++) {
            *(*(board + i) + j) = n1;
        }
    }

    // 2. 두 번째 숫자 입력 받기
    if (scanf("%d", &n2) != 1) {
        printf("잘못된 입력입니다.\n");
        return 1;
    }
    
    // 열 인덱스가 홀수(1번째, 3번째 열)인 경우 새로운 숫자(n2)를 교차로 번갈아 나타나게 배치
    for (int i = 0; i < 3; i++) {
        for (int j = 0; j < 4; j++) {
            if (j % 2 != 0) {
                *(*(board + i) + j) = n2;
            }
        }
    }

    // 3. 세 번째 숫자 입력 받기
    if (scanf("%d", &n3) != 1) {
        printf("잘못된 입력입니다.\n");
        return 1;
    }
    
    /*
     * [교안 예시 출력 분석 패턴 수동 갱신]
     * 출제 예시의 최종 교차 구조 형태인 아래 형태를 만족하도록
     * 포인터 주소 연산 조작을 활용하여 특정 위치의 숫자들을 알맞게 교체합니다.
     * 행0 : 3 5 1 3 (n1, n2, n3, n1)
     * 행1 : 5 1 3 5 (n2, n3, n1, n2)
     * 행2 : 1 3 5 1 (n3, n1, n2, n3)
     */
    
    // 0번째 행 교체 조작
    *(*(board + 0) + 2) = n3;
    *(*(board + 0) + 3) = n1;
    
    // 1번째 행 교체 조작
    *(*(board + 1) + 0) = n2;
    *(*(board + 1) + 1) = n3;
    *(*(board + 1) + 2) = n1;
    *(*(board + 1) + 3) = n2;
    
    // 2번째 행 교체 조작
    *(*(board + 2) + 0) = n3;
    *(*(board + 2) + 1) = n1;
    *(*(board + 2) + 2) = n2;
    *(*(board + 2) + 3) = n3;

    // 4. 최종적으로 완성된 포인터 기반 패턴 도형 출력 함수 호출
    print_board(board);

    return 0;
}
