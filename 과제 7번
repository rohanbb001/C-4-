#include <stdio.h>
#include <stdlib.h>

/* ----------------------------------------
   Node: 연결 리스트의 한 칸(자료 + 다음 노드 포인터)
   Data 자료형은 자유롭게 바꿀 수 있도록 int로 설정 (필요시 변경)
---------------------------------------- */
typedef struct _Node {
    int data;              // 저장할 데이터
    struct _Node* next;    // 다음 노드를 가리키는 포인터
} Node;

/* ----------------------------------------
   LinkedList: 리스트 전체를 관리하는 구조체
   head - 첫 번째 노드
   tail - 마지막 노드
   cur  - 탐색용 커서 (필요시 사용)
   size - 현재 노드 개수
---------------------------------------- */
typedef struct _LinkedList {
    Node* head;
    Node* tail;
    Node* cur;
    int size;
} LinkedList;

/* ----------------------------------------
   리스트 초기화
---------------------------------------- */
void init_list(LinkedList* list) {
    list->head = NULL;
    list->tail = NULL;
    list->cur = NULL;
    list->size = 0;
}

/* ----------------------------------------
   새 노드 생성 (동적 할당)
---------------------------------------- */
Node* create_node(int data) {
    Node* new_node = (Node*)malloc(sizeof(Node));
    if (new_node == NULL) {
        printf("메모리 할당 실패\n");
        exit(1);
    }
    new_node->data = data;
    new_node->next = NULL;
    return new_node;
}

/* ----------------------------------------
   insert_first : 리스트 맨 처음에 노드 추가
---------------------------------------- */
void insert_first(LinkedList* list, int data) {
    Node* new_node = create_node(data);

    if (list->head == NULL) {
        // 리스트가 비어있는 경우 -> head, tail 모두 새 노드
        list->head = new_node;
        list->tail = new_node;
    }
    else {
        // 새 노드가 기존 head를 가리키고, head를 새 노드로 갱신
        new_node->next = list->head;
        list->head = new_node;
    }
    list->size++;
}

/* ----------------------------------------
   insert_back : 리스트 맨 끝에 노드 추가
---------------------------------------- */
void insert_back(LinkedList* list, int data) {
    Node* new_node = create_node(data);

    if (list->head == NULL) {
        // 리스트가 비어있는 경우
        list->head = new_node;
        list->tail = new_node;
    }
    else {
        // 기존 tail의 next가 새 노드를 가리키고, tail을 새 노드로 갱신
        list->tail->next = new_node;
        list->tail = new_node;
    }
    list->size++;
}

/* ----------------------------------------
   insert : 원하는 위치(index)에 노드 삽입
   index는 0부터 시작 (0이면 맨 앞, size면 맨 뒤)
---------------------------------------- */
void insert(LinkedList* list, int index, int data) {
    if (index < 0 || index > list->size) {
        printf("insert 실패: 잘못된 index (%d)\n", index);
        return;
    }

    if (index == 0) {
        insert_first(list, data);
        return;
    }
    if (index == list->size) {
        insert_back(list, data);
        return;
    }

    // index-1번째 노드(삽입할 위치의 바로 앞 노드)까지 이동
    Node* prev = list->head;
    for (int i = 0; i < index - 1; i++) {
        prev = prev->next;
    }

    Node* new_node = create_node(data);
    new_node->next = prev->next; // 새 노드가 뒤쪽을 가리키게 연결
    prev->next = new_node;       // 앞 노드가 새 노드를 가리키게 연결
    list->size++;
}

/* ----------------------------------------
   insert_by_data : 특정 data 값을 가진 노드 "뒤"에 삽입
   (data 기준 삽입 기능)
---------------------------------------- */
void insert_by_data(LinkedList* list, int target_data, int data) {
    Node* cur = list->head;
    while (cur != NULL) {
        if (cur->data == target_data) {
            if (cur == list->tail) {
                insert_back(list, data);
            }
            else {
                Node* new_node = create_node(data);
                new_node->next = cur->next;
                cur->next = new_node;
                list->size++;
            }
            return;
        }
        cur = cur->next;
    }
    printf("insert_by_data 실패: data(%d)를 찾을 수 없음\n", target_data);
}

/* ----------------------------------------
   delete_first : 맨 처음 노드 삭제
---------------------------------------- */
void delete_first(LinkedList* list) {
    if (list->head == NULL) {
        printf("delete_first 실패: 빈 리스트\n");
        return;
    }

    Node* temp = list->head;
    list->head = list->head->next;

    if (list->head == NULL) {
        // 노드가 하나뿐이었던 경우 tail도 NULL로
        list->tail = NULL;
    }

    free(temp); // 메모리 해제
    list->size--;
}

/* ----------------------------------------
   delete_back : 맨 마지막 노드 삭제
---------------------------------------- */
void delete_back(LinkedList* list) {
    if (list->head == NULL) {
        printf("delete_back 실패: 빈 리스트\n");
        return;
    }

    if (list->head == list->tail) {
        // 노드가 하나뿐인 경우
        free(list->head);
        list->head = NULL;
        list->tail = NULL;
        list->size--;
        return;
    }

    // 단순 연결 리스트는 이전 노드를 알 수 없으므로 처음부터 탐색
    Node* cur = list->head;
    while (cur->next != list->tail) {
        cur = cur->next;
    }

    free(list->tail);
    cur->next = NULL;
    list->tail = cur;
    list->size--;
}

/* ----------------------------------------
   delete_by_index : index번째 노드 삭제
---------------------------------------- */
void delete_by_index(LinkedList* list, int index) {
    if (index < 0 || index >= list->size) {
        printf("delete_by_index 실패: 잘못된 index (%d)\n", index);
        return;
    }

    if (index == 0) {
        delete_first(list);
        return;
    }
    if (index == list->size - 1) {
        delete_back(list);
        return;
    }

    // 삭제할 노드의 바로 앞 노드까지 이동
    Node* prev = list->head;
    for (int i = 0; i < index - 1; i++) {
        prev = prev->next;
    }

    Node* target = prev->next;
    prev->next = target->next; // 삭제할 노드를 건너뛰고 연결
    free(target);
    list->size--;
}

/* ----------------------------------------
   delete_by_data : 특정 data 값을 가진 첫 번째 노드 삭제
---------------------------------------- */
void delete_by_data(LinkedList* list, int data) {
    if (list->head == NULL) {
        printf("delete_by_data 실패: 빈 리스트\n");
        return;
    }

    // 삭제 대상이 head인 경우
    if (list->head->data == data) {
        delete_first(list);
        return;
    }

    Node* prev = list->head;
    Node* cur = list->head->next;

    while (cur != NULL) {
        if (cur->data == data) {
            prev->next = cur->next;
            if (cur == list->tail) {
                list->tail = prev; // 삭제 대상이 tail이었던 경우 tail 갱신
            }
            free(cur);
            list->size--;
            return;
        }
        prev = cur;
        cur = cur->next;
    }

    printf("delete_by_data 실패: data(%d)를 찾을 수 없음\n", data);
}

/* ----------------------------------------
   get_entry_by_index : index로 data 값을 찾아 반환
   실패 시 -1 반환 (found를 통해 성공 여부도 알려줌)
---------------------------------------- */
int get_entry_by_index(LinkedList* list, int index, int* found) {
    if (index < 0 || index >= list->size) {
        *found = 0;
        return -1;
    }

    Node* cur = list->head;
    for (int i = 0; i < index; i++) {
        cur = cur->next;
    }

    *found = 1;
    return cur->data;
}

/* ----------------------------------------
   get_entry_by_data : data 값으로 index를 찾아 반환
   찾지 못하면 -1 반환
---------------------------------------- */
int get_entry_by_data(LinkedList* list, int data) {
    Node* cur = list->head;
    int index = 0;

    while (cur != NULL) {
        if (cur->data == data) {
            return index;
        }
        cur = cur->next;
        index++;
    }

    return -1; // 못 찾은 경우
}

/* ----------------------------------------
   get_length : 리스트 전체 길이 반환
---------------------------------------- */
int get_length(LinkedList* list) {
    return list->size;
}

/* ----------------------------------------
   print_list : 리스트의 모든 요소 출력
---------------------------------------- */
void print_list(LinkedList* list) {
    Node* cur = list->head;

    printf("[ ");
    while (cur != NULL) {
        printf("%d ", cur->data);
        cur = cur->next;
    }
    printf("] (size = %d)\n", list->size);
}

/* ----------------------------------------
   reverse : 리스트를 역순으로 만들기
   포인터 3개(prev, cur, next_node)를 이용해 방향을 뒤집는다
---------------------------------------- */
void reverse(LinkedList* list) {
    Node* prev = NULL;
    Node* cur = list->head;
    Node* next_node = NULL;

    list->tail = list->head; // 기존 head가 새로운 tail이 됨

    while (cur != NULL) {
        next_node = cur->next; // 다음 노드를 미리 저장
        cur->next = prev;      // 화살표 방향을 뒤집음
        prev = cur;             // prev를 한 칸 전진
        cur = next_node;        // cur를 한 칸 전진
    }

    list->head = prev; // 마지막으로 prev가 가리키던 노드가 새로운 head
}

/* ----------------------------------------
   free_list : 프로그램 종료 전 모든 노드 메모리 해제
---------------------------------------- */
void free_list(LinkedList* list) {
    Node* cur = list->head;
    while (cur != NULL) {
        Node* temp = cur;
        cur = cur->next;
        free(temp);
    }
    list->head = NULL;
    list->tail = NULL;
    list->size = 0;
}

/* ----------------------------------------
   main : 각 함수 동작을 테스트
---------------------------------------- */
int main(void) {
    LinkedList list;
    init_list(&list);

    printf("--- insert_back으로 100, 200, 300 추가 ---\n");
    insert_back(&list, 100);
    insert_back(&list, 200);
    insert_back(&list, 300);
    print_list(&list);

    printf("\n--- insert_first로 50 추가 ---\n");
    insert_first(&list, 50);
    print_list(&list);

    printf("\n--- insert(index=2, data=999) : 3번째 자리에 삽입 ---\n");
    insert(&list, 2, 999);
    print_list(&list);

    printf("\n--- insert_by_data(300, 400) : data 300 뒤에 400 삽입 ---\n");
    insert_by_data(&list, 300, 400);
    print_list(&list);

    printf("\n--- get_length ---\n");
    printf("현재 길이: %d\n", get_length(&list));

    printf("\n--- get_entry_by_index(2) : index 2의 data ---\n");
    int found;
    int val = get_entry_by_index(&list, 2, &found);
    if (found) printf("index 2 -> data: %d\n", val);

    printf("\n--- get_entry_by_data(999) : data 999의 index ---\n");
    int idx = get_entry_by_data(&list, 999);
    printf("data 999 -> index: %d\n", idx);

    printf("\n--- delete_by_data(999) ---\n");
    delete_by_data(&list, 999);
    print_list(&list);

    printf("\n--- delete_by_index(0) : 맨 앞 삭제 ---\n");
    delete_by_index(&list, 0);
    print_list(&list);

    printf("\n--- delete_back() : 맨 뒤 삭제 ---\n");
    delete_back(&list);
    print_list(&list);

    printf("\n--- reverse() : 리스트 역순으로 변경 ---\n");
    reverse(&list);
    print_list(&list);

    free_list(&list); // 메모리 해제
    return 0;
}
